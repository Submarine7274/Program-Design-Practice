# 5. 使用 ggplot2 繪製時間序列折線圖
# 為什麼要這樣寫：ggplot2 採用「圖層 (Layer)」的概念。
# ggplot() 定義畫布與資料映射，geom_line() 疊加折線圖層，labs() 疊加文字標籤圖層。
ggplot(data = plot_data, aes(x = date, y = percentage, color = name)) +
geom_line(size = 1) + # size = 1 讓線條稍微加粗，便於閱讀
theme_minimal() +     # 使用白底、去邊框的簡約主題，降低視覺干擾
labs(
title = paste("Steam 硬體歷史趨勢分析：", target_category),
subtitle = "觀察現象級事件對特定硬體市佔率的波動影響",
x = "年份 (Year)",
y = "市佔率 (Percentage)",
color = "硬體名稱"
) +
# 將 Y 軸的 0.15 自動格式化為 15%，提升圖表可讀性
scale_y_continuous(labels = percent_format(accuracy = 1)) +
# 將 X 軸的刻度設定為每 2 年顯示一次，避免年份文字擠在一起
scale_x_date(date_breaks = "2 years", date_labels = "%Y")
