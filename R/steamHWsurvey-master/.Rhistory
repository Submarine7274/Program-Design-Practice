# 2. 將垂直線與文字圖層疊加
p_trend <- p_trend +
# 加入垂直虛線 (維持不變)
geom_vline(
data = os_events,
aes(xintercept = event_date),
color = "#555555",
linetype = "dashed",
linewidth = 0.6,
alpha = 0.8
) +
# 【關鍵修正】：將 geom_text 替換為 geom_label_repel
geom_label_repel(
data = os_events,
aes(x = event_date, y = y_max, label = event_label),
nudge_y = 0.05,             # 初始推力：統一將所有文字先往上推離圖表頂部
direction = "both",         # 物理引擎設定：允許文字在 X 軸與 Y 軸雙向推擠排開
segment.color = "#aaaaaa",  # 若文字被推離原位，自動畫一條灰色的引導線連回原本的日期
segment.linetype = "dotted",# 引導線設定為點狀線
fill = alpha("white", 0.8), # 加上半透明白色底框，確保文字不會與背景的折線或虛線混淆
color = "#333333",
size = 3.5,
fontface = "bold",
inherit.aes = FALSE
)
